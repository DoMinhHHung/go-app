APP_ENV=development
APP_PORT=8080
APP_NAME=identity-service

DATABASE_URL=postgres://postgres:password@localhost:5432/go_identity?sslmode=disable

REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

RABBITMQ_HOST=your-rabbitmq-host
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=your-rabbitmq-username
RABBITMQ_PASSWORD=your-rabbitmq-password
RABBITMQ_VHOST=your-rabbitmq-vhost

JWT_ACCESS_SECRET=replace-with-a-secure-secret
JWT_REFRESH_SECRET=replace-with-a-secure-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

OTP_TTL=5m
OTP_MAX_RESEND_PER_HOUR=5

RATE_LIMIT_IP_MAX=30
RATE_LIMIT_IP_TTL=1m
RATE_LIMIT_DEVICE_MAX=10
RATE_LIMIT_DEVICE_TTL=1h

RABBITMQ_EXCHANGE=notification.direct
RABBITMQ_ROUTING_KEY_EMAIL=email.send
RABBITMQ_ROUTING_KEY_USER_SYNC=user.sync